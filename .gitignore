# Secrets / per-machine config (created from the .sample files on each host)
website/config.php
agent/agent.conf

# Build output
agent/Agent.exe
agent/agentsvc.exe
agent/Agent.new.exe
agent/Agent.prev.exe
agent/*.pdb
agent/Embedded.cs
agent/agent.id
agent/worker.hb
agent/update.flag

# Runtime command queue (keep the folder + .htaccess, ignore live cmd/res files)
website/data/*/
website/data/*.json

# Local test scratch
_agenttest/

# PyInstaller build output for the Python subprojects. Each subproject's own .gitignore commits
# its dist/<exe> and ignores the rest (see CLAUDE.md "Compiled tool exes ARE committed"), so do
# NOT blanket-ignore dist/ here — that would block re-including the committed exe.
build_pyi/
__pycache__/

# OS / editor noise
Thumbs.db
.DS_Store
*.log
