# rmdownloader agent configuration (key=value, one per line).
# OPTIONAL — you can skip this file entirely and just run:  Agent.exe <token>
# (server defaults to https://dos.argonar.co). Copy to agent.conf to set defaults here
# instead. Command-line arguments override this file.
# The agent only makes OUTBOUND calls to 'server', so it works from behind home NAT
# with no port-forwarding or tunnel.

# Your VPS site (HTTPS recommended).
server=https://dos.argonar.co

# Long random secret. Must match this PC's token in the website's config.php.
token=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET

# Optional sandbox: restrict all access to this folder and below. Empty = whole machine.
# root=C:\shared
root=
